# LOG-mcp Configuration
# Copy this to docker/.env and fill in your values

# === REQUIRED ===
# Your cloud LLM API key (DeepSeek, OpenAI, etc.)
LOG_API_KEY=sk-your-api-key-here

# Passphrase for logging into the chat UI
LOG_PASSPHRASE=changeme

# === CLOUD MODELS ===
# Cheap/fast model (handles most requests)
LOG_CHEAP_MODEL_ENDPOINT=https://api.deepseek.com/v1/chat/completions
LOG_CHEAP_MODEL_NAME=deepseek-chat

# Escalation model (for complex reasoning)
LOG_ESCALATION_MODEL_ENDPOINT=https://api.deepseek.com/v1/chat/completions
LOG_ESCALATION_MODEL_NAME=deepseek-reasoner

# === LOCAL INFERENCE ===
# Ollama URL (for local LLM, optional)
LOG_OLLAMA_BASE_URL=http://localhost:11434

# === ROUTING BEHAVIOR ===
# Fire cheap model immediately (don't wait for router)
LOG_INSTANT_SEND=true

# Enable draft round mode (compare multiple approaches)
LOG_DRAFT_MODE=true

# Privacy mode: always strip PII before cloud calls
LOG_PRIVACY_MODE=true

# === SERVER ===
LOG_LOCAL_PORT=8000
