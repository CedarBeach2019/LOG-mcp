# LOG-mcp Configuration
# Copy this to .env and fill in your values

# Your cloud LLM API key (DeepSeek, OpenAI, etc.)
LOG_API_KEY=sk-your-api-key-here

# API endpoint (DeepSeek default shown)
LOG_PROVIDER_ENDPOINT=https://api.deepseek.com/v1/chat/completions

# Passphrase for logging into the chat UI
LOG_PASSPHRASE=changeme

# Local port
LOG_LOCAL_PORT=8000
