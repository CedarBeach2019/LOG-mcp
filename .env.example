# L.O.G. — Latent Orchestration Gateway

# ============================================
# LOCAL VAULT (always required)
# ============================================
VAULT_DB_PATH=~/.log/vault/reallog.db

# ============================================
# MODE 1: CLOUDFLARE WORKER (privacy proxy)
# ============================================
# Set these in Cloudflare Worker secrets (.dev.vars for local, dashboard for prod)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
AI_API_KEY=                    # DeepSeek, OpenAI, etc.
PROVIDER_ENDPOINT=https://api.deepseek.com/v1/chat/completions

# ============================================
# MODE 2: HYBRID (Cloudflare + Local LLM)
# ============================================
OLLAMA_HOST=http://localhost:11434  # Local Ollama for smart redaction
OLLAMA_MODEL=qwen2.5-coder:7b

# ============================================
# SCOUTS (optional AI provider keys)
# ============================================
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ============================================
# MCP SERVER (optional)
# ============================================
MCP_HOST=127.0.0.1
MCP_PORT=8000

# ============================================
# CLOUDFLARE TUNNEL (for hybrid mode)
# ============================================
CLOUDFLARE_TUNNEL_TOKEN=
