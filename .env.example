# ============================================================
# LOG-mcp Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Required ---

# Your AI provider API key (DeepSeek recommended — free tier available)
# Get one at https://platform.deepseek.com
LOG_API_KEY=sk-your-api-key-here

# Passphrase for logging into the web UI and authenticating API calls
# This is your admin password — make it strong
LOG_PASSPHRASE=change-this-to-something-secure

# --- Optional: Model Selection ---

# Model to use for simple queries (facts, greetings, basic Q&A)
LOG_CHEAP_MODEL=deepseek-chat

# Model to use for complex queries (code, reasoning, analysis)
LOG_ESCALATION_MODEL=deepseek-reasoner

# --- Optional: Privacy ---

# Strip PII (emails, phones, names) before sending to cloud APIs
# Default: true
LOG_PRIVACY_MODE=true

# --- Optional: Caching ---

# Cache semantically similar queries locally (requires sentence-transformers)
# Default: true (falls back to disabled if sentence-transformers not installed)
LOG_CACHE_ENABLED=true

# --- Optional: Storage ---

# Path to the SQLite database
# Default: ~/.log/vault.db
# LOG_DB_PATH=~/.log/vault.db

# --- Optional: Server ---

# Allowed CORS origins (comma-separated)
# Default: http://localhost:8000
# Set to * to allow all origins (not recommended for production)
LOG_CORS_ORIGINS=http://localhost:8000

# JWT signing secret (auto-generated if not set)
# Set this for production to persist tokens across restarts
# LOG_JWT_SECRET=

# Max streaming response time in seconds
# Default: 120
# LOG_STREAM_TIMEOUT=120

# Max request body size in bytes
# Default: 1048576 (1MB)
# LOG_MAX_BODY_SIZE=1048576

# --- Optional: Local Inference ---

# Run models in an isolated subprocess (needed on Jetson / low-memory devices)
# Default: false (auto-detected on Jetson)
# LOG_LOCAL_USE_SUBPROCESS=false

# Path to local GGUF models directory
# Default: ~/.log/models
# LOG_MODEL_DIR=~/.log/models

# --- Optional: Additional Providers ---

# Groq (https://console.groq.com)
# LOG_GROQ_API_KEY=gsk_your-groq-key

# OpenAI (https://platform.openai.com)
# LOG_OPENAI_API_KEY=sk-your-openai-key

# OpenRouter (https://openrouter.ai)
# LOG_OPENROUTER_API_KEY=sk-or-your-openrouter-key
