# L.O.G. Environment Variables
# Copy this file to .env and fill in your values

# Vault Database
VAULT_DB_PATH=~/.log/vault/reallog.db

# Local Redactor Service (if using Docker)
REDACTOR_HOST=localhost
REDACTOR_PORT=8000

# Cloudflare Ghost (optional)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_WORKER_NAME=log-gateway

# Scout API Keys (optional)
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Hysteresis Pruning Settings
PRUNE_HOT_DAYS=7
PRUNE_WARM_DAYS=30
PRUNE_COLD_DAYS=90

# Archive Settings
ARCHIVE_PATH=~/.log/archive
MAX_ARCHIVE_SIZE_GB=10
